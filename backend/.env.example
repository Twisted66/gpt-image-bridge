# Image Bridge Environment Variables

# API Key for authentication (used by Custom GPT)
# Generate a secure random key with: openssl rand -hex 32
IMAGE_BRIDGE_API_KEY=your_api_key_here

# Bearer token (alternative authentication method)
# Keep this secure and rotate regularly
IMAGE_BRIDGE_ALLOWED_BEARER=your_bearer_token_here

# CORS origins (comma-separated list, e.g., "https://chat.openai.com,https://chatgpt.com")
# Use "*" for development only - never in production
CORS_ORIGINS=*
